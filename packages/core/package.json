    "./plugins": "./src/plugins/index.ts",
    "./config": "./src/config/index.ts"
  },
  "scripts": {
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0 || ^5.0.0",
    "pinia": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "pinia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@charsle/micro-shared": "workspace:*",
