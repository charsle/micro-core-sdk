{
  "name": "@axewo/micro-core",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Micro Frontend Core — Store, permissions, guards, error handling, env config",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0 || ^5.0.0",
    "pinia": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "pinia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axewo/micro-shared": "^1.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.0",
    "pinia": "^3.0.0"
  }
}