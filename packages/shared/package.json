{
  "name": "@axewo/micro-shared",
  "version": "1.0.1",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Shared utilities for micro-frontend platform — micro-app communication, request, auth, types",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0 || ^5.0.0",
    "vue-i18n": "^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "vue-i18n": {
      "optional": true
    },
    "axios": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "axios": "^1.18.1",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0",
    "vue-i18n": "^11.4.6"
  }
}